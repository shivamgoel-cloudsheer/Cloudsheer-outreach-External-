# Auth.js - generate with: npx auth secret
AUTH_SECRET=

# Google OAuth client (Google Cloud Console > Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Neon Postgres connection string
DATABASE_URL=

# Resend
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM="CloudSheer <hello@mail.cloudsheer.com>"
RESEND_REPLY_TO=solutions@cloudsheer.com

# Public base URL of the deployed app (used in unsubscribe links)
APP_URL=http://localhost:3000

# Secret for the daily cron trigger (also set in Vercel)
CRON_SECRET=

# Site-wide access password (the gate screen before anything loads)
ACCESS_PASSWORD=
